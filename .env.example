# Alpaca Credentials
ALPACA_API_KEY_ID=your_api_key
ALPACA_SECRET_KEY=your_secret_key
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets

# Google Gemini API
GOOGLE_GENAI_API_KEY=your_gemini_api_key

# Value Steward Operational Modes
# Options: LOW, MEDIUM, HIGH
VS_MODE=LOW
VS_SHADOW_MODE=true
VS_EXECUTION_ARMED=false

# Portfolio Configuration
VS_CORE_SYMBOL=SPY
TARGET_RISK_EXPOSURE_PCT_LOW=0.20
TARGET_RISK_EXPOSURE_PCT_MEDIUM=0.40
TARGET_RISK_EXPOSURE_PCT_HIGH=0.60
REBALANCE_BUFFER_PCT=0.02

# Capital Controls
MAX_EFFECTIVE_CAPITAL_DOLLARS=20.0
MAX_TRADE_NOTIONAL_DOLLARS=5.0
MIN_TRADE_NOTIONAL_DOLLARS=1.0

# Circuit Breakers
VS_MAX_DAILY_LOSS_PCT=0.03
VS_MAX_SIGNAL_AGE_DAYS=1

# Signal Weights
VS_SIGNAL_W_RANK_MOM=1.0
VS_SIGNAL_W_RANK_VOL=0.4
VS_SIGNAL_W_RANK_DD=0.4

# Market Hours & Timing
VS_MARKET_TIMEZONE=America/New_York
VS_USE_ALPACA_CLOCK=false
VS_MARKET_OPEN_TIME=09:30
VS_MARKET_CLOSE_TIME=16:00

# Email Notifications (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=ValueSteward <your_email@gmail.com>
EMAIL_TO=recipient@gmail.com

# Health Monitoring
VS_EMAIL_HEALTH=true
VS_HEALTH_TICK_MAX_HOURS=2
VS_HEALTH_WORLD_MAX_HOURS_OPEN=6

# Push Notifications (ntfy) — market-open "VS live", session "VS off", and
# health alerts. Install the ntfy app, subscribe to a SECRET topic name
# (anyone who knows the topic can read your pushes on public ntfy.sh), then set
# VS_NTFY_TOPIC. Verify with `npm run push:test`. Leave VS_NTFY_TOPIC unset to
# disable pushes (the system no-ops gracefully).
VS_NTFY_TOPIC=
VS_NTFY_SERVER=https://ntfy.sh
# VS_NTFY_TOKEN=        # bearer token, only for self-hosted / reserved topics
VS_PUSH_ENABLED=true
# Min hours before re-pushing the SAME health-alert signature (a new/different
# issue set always alerts immediately; cleared issues reset the throttle).
VS_PUSH_HEALTH_ALERT_MIN_HOURS=6
# Base URL for tappable report links in pushes (e.g. a hosted weekly tearsheet).
# Unset = no link. Set once reports are web-served (e.g. after the Oracle move).
VS_REPORT_BASE_URL=
