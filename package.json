  "devDependencies": {
    "eslint": "^8.57.0"
  },
  "dependencies": {
    "@alpacahq/alpaca-trade-api": "^1.4.2",
    "@google/genai": "^1.44.0",
    "@mozilla/readability": "^0.6.0",
