{
  "name": "value-steward",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "train:policy": "node scripts/trainPolicy.js",
    "email:test": "node scripts/testEmail.js",
    "push:test": "node scripts/pushTest.js",
    "notify:open": "node scripts/marketOpenNotice.js",
    "notify:close": "node scripts/marketCloseNotice.js",
    "local:tick": "node local/runValueStewardTick.js",
    "local:tick:scheduled": "node scripts/localTickScheduled.js",
    "intraday:observe": "node scripts/intradayObservation.js",
    "intraday:observe:scheduled": "node scripts/intradayObservationScheduled.js",
    "portfolio:refresh": "node scripts/portfolioRefresh.js",
    "intent:reconcile": "node scripts/intentReconcile.js",
    "execution:quality": "node scripts/executionQualityReport.js",
    "gate:calibration": "node scripts/gateCalibration.js",
    "scorecard:refresh": "node scripts/scorecardRefresh.js",
    "lint:py": "node scripts/lintPy.js",
    "format:py": "node scripts/formatPy.js",
    "test:js": "node --test --test-concurrency=1 tests-js/*.test.js",
    "test:py": ".venv/bin/python3 -m pytest tests/",
    "typecheck:py": "node scripts/typecheckPy.js",
    "security:py": "node scripts/securityPy.js",
    "lint:js": "eslint .",
    "lint": "npm run lint:js && npm run lint:py",
    "check": "npm run test:js && npm run test:py && npm run lint",
    "audit:js": "npm audit",
    "phase1:run": "node scripts/phase1Run.js",
    "phase1:status": "node scripts/phase1Status.js",
    "eod:run": "node scripts/eodRun.js",
    "time:check": "node scripts/timeCheck.js",
    "health:check": "node scripts/healthCheck.js",
    "runtime:status": "node scripts/runtimeStatus.js",
    "runtime:watch": "node scripts/runtimeStatus.js --watch=10",
    "runtime:append": "node scripts/runtimeStatus.js --format=jsonl --append",
    "world:influence": "node scripts/worldInfluence.js",
    "controls:status": "node scripts/controls.js status",
    "controls:enable": "node scripts/controls.js enable",
    "controls:disable": "node scripts/controls.js disable",
    "controls:force-no-trade": "node scripts/controls.js force-no-trade",
    "controls:clear": "node scripts/controls.js clear",
    "gpio:daemon": "node scripts/gpioDaemon.js",
    "gpio:once": "node scripts/gpioDaemon.js --once",
    "gpio:sim": "node scripts/gpioSim.js",
    "gpio:sim:enable": "node scripts/gpioSim.js enable",
    "gpio:sim:disable": "node scripts/gpioSim.js disable",
    "gpio:sim:force-no-trade": "node scripts/gpioSim.js force-no-trade",
    "gpio:sim:clear": "node scripts/gpioSim.js clear",
    "world:fetch": "node world/fetchRss.js",
    "world:hydrate": "node world/hydrateLinks.js",
    "world:build": "node world/buildWorldContext.js",
    "world:run": "npm run world:fetch && npm run world:hydrate && npm run world:build",
    "world:inspect": "node world/inspectWorldContext.js",
    "world:health": "node world/healthReport.js",
    "world:health:refresh": "node world/healthReport.js --refresh-if-stale",
    "world:health:scheduled": "WORLD_FEED_AUTO_DISABLE=false node world/healthReport.js --refresh-if-stale",
    "world:run:scheduled": "node scripts/worldRunScheduled.js",
    "eod:run:scheduled": "node scripts/eodRunScheduled.js",
    "report:weekly": "node scripts/weeklyReport.js",
    "desktop": "node scripts/desktop.js"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.9.4"
  },
  "dependencies": {
    "@alpacahq/alpaca-trade-api": "^3.1.3",
    "@google/genai": "^1.44.0",
    "@massive.com/client-js": "^10.5.0",
    "@mozilla/readability": "^0.6.0",
    "dotenv": "^16.0.0",
    "jsdom": "^24.0.0",
    "nodemailer": "^7.0.12",
    "rss-parser": "^3.13.0",
    "sqlite3": "^6.0.1"
  }
}
